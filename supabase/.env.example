# ─── Dodo Payments ───────────────────────────────
DODO_API_KEY="your-dodo-api-key"
DODO_BASE_URL="https://test.dodopayments.com"       # Use https://api.dodopayments.com for live
DODO_WEBHOOK_SECRET="your-webhook-secret"

# ─── App ─────────────────────────────────────────
APP_BASE_URL="http://localhost:8080"                  # Your frontend URL

# ─── Billing ─────────────────────────────────────
BILLING_GRACE_DAYS=3                                  # Days after period end before access is paused
REMINDER_SCHEDULE_HOURS="24,6"                        # Hours after due to send reminder 1, 2, etc.
CRON_SECRET="your-cron-secret"                        # Secret for triggering billing-scheduler

